// 核战争城市自救地球仪 - 主应用逻辑（修复版 v3.0）
// 使用 Cesium.js 构建 3D 地球仪，确保边界正确显示

let viewer;
let shelterEntities = [];
let currentCity = null;

// ============ 初始化 Cesium 地球仪 ============
function initGlobe() {
    console.log('[Nuclear Globe] Starting initialization v3.0...');
    
    // 设置 Cesium Ion Token（使用公开可用的测试token，主要使用开源数据源）
    Cesium.Ion.defaultAccessToken = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJqdGkiOiJlYWE3ZDAxZS1jZDZlLTQ3M2ItYjBlZC0wY2Y3ODAzOTYwM2QiLCJpZCI6NjEwMjYsImlhdCI6MTcyODI4MjE1OH0.KfKywGAydzCeL6z7eaoU69F2MoCz1K3nXW2OjXh0Pxs';
    
    try {
        // 初始化 Viewer - 使用可靠的默认底图
        viewer = new Cesium.Viewer('cesiumContainer', {
            // 使用 Bing Maps 作为默认底图（最可靠）
            imageryProvider: new Cesium.BingMapsImageryProvider({
                key: 'Agy2p8F1tRE4dYK_Qb7gHY_5tIp0OUrsTqdD50B_RhI4pZP4nB0vFWL8f6Jygw0E', // 公开测试key
                mapStyle: Cesium.BingMapsStyle.AERIAL_WITH_LABELS
            }),
            terrainProvider: Cesium.createWorldTerrain({
                requestWaterMask: true,
                requestVertexNormals: true
            }),
            baseLayerPicker: true, // 启用图层选择器让用户切换
            geocoder: true,
            homeButton: true,
            sceneModePicker: true,
            navigationHelpButton: false,
            animation: false,
            timeline: false,
            fullscreenButton: false,
            vrButton: false
        });
        
        console.log('[Nuclear Globe] Viewer created with Bing Maps');
    } catch (e) {
        console.error('[Nuclear Globe] Failed to create viewer with Bing, trying fallback...', e);
        
        // 备用方案：使用 Natural Earth 数据
        viewer = new Cesium.Viewer('cesiumContainer', {
            imageryProvider: new Cesium.TileMapServiceImageryProvider({
                url: Cesium.buildModuleUrl('Assets/Textures/NaturalEarthII')
            }),
            terrainProvider: new Cesium.EllipsoidTerrainProvider(),
            baseLayerPicker: true,
            geocoder: false,
            homeButton: true,
            sceneModePicker: true,
            navigationHelpButton: false,
            animation: false,
            timeline: false
        });
    }
    
    // 设置视觉效果
    setupVisualEffects();
    
    // 加载边界和标记
    loadWorldBoundaries();
    loadChinaBoundaries();
    loadCityMarkers();
    
    // 生成避难所数据
    if (typeof SHELTER_DATA !== 'undefined') {
        generateShelterEntities();
        populateCityList();
        updateStats();
    }
    
    // 绑定事件
    setupEventHandlers();
    
    // 初始视角 - 中国
    flyToChina();
    
    // 隐藏加载动画
    setTimeout(() => {
        const loading = document.getElementById('loading');
        if (loading) loading.classList.add('hidden');
    }, 2000);
    
    console.log('[Nuclear Globe] Initialization complete!');
}

// ============ 视觉效果设置 ============
function setupVisualEffects() {
    const scene = viewer.scene;
    const globe = scene.globe;
    
    // 深空背景
    scene.backgroundColor = Cesium.Color.fromCssColorString('#0a0a1a');
    
    // 启用光照
    globe.enableLighting = true;
    globe.lightingFadeOutDistance = 100000;
    globe.lightingFadeInDistance = 10000000;
    
    // 大气效果
    scene.skyAtmosphere.show = true;
    scene.skyAtmosphere.hueShift = 0.0;
    scene.skyAtmosphere.saturationShift = -0.3;
    scene.skyAtmosphere.brightnessShift = -0.1;
    
    // 雾效果增加深度感
    scene.fog.enabled = true;
    scene.fog.density = 0.0001;
    scene.fog.minimumBrightness = 0.05;
    
    // 禁用默认UI元素
    viewer.selectionIndicator.show = false;
    viewer.infoBox.show = false;
    
    // 相机控制设置
    scene.screenSpaceCameraController.minimumZoomDistance = 1000;
    scene.screenSpaceCameraController.maximumZoomDistance = 50000000;
    scene.screenSpaceCameraController.enableTilt = true;
    
    // 启用HDR
    scene.highDynamicRange = true;
    
    console.log('[Nuclear Globe] Visual effects configured');
}

