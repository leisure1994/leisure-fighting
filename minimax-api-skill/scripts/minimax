Usage: minimax music [prompt] [options]

Options:
  --model, -m         模型 (default: music-2.5)
  --duration, -d      时长秒数 (default: 30)
  --output, -o        输出文件 (default: output.mp3)

Examples:
  minimax music "轻快的钢琴曲"
  minimax music "史诗交响乐" --duration 60 --output epic.mp3
EOF
                return
                ;;
            *)
                if [ -z "$prompt" ]; then
                    prompt="$1"
                fi
                shift
                ;;
        esac
    done

    if [ -z "$prompt" ]; then
