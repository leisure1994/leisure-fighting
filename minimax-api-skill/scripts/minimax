    local audio_url=$(echo "$response" | jq -r '.audio_url // empty' 2>/dev/null)

    if [ -n "$audio_url" ] && [ "$audio_url" != "null" ]; then
        echo -e "${GREEN}下载音乐到 ${output}...${NC}"
        curl -s -L "$audio_url" -o "$output"
        echo -e "${GREEN}✓ 已保存: ${output}${NC}"
    else
        echo -e "${RED}Error: 音乐生成失败${NC}"
        echo "$response" | jq . 2>/dev/null || echo "$response"
        exit 1
    fi
}

# Status command
status_command() {
    local api_key=$(check_api_key)
    
    echo -e "${GREEN}MiniMax API Status${NC}"
    echo "=================="
    echo "API Key: ${api_key:0:10}..."
    echo "Base URL: ${MINIMAX_BASE_URL}"
    echo ""
    echo -e "${YELLOW}可用命令:${NC}"
    echo "  chat    - 文本对话"
    echo "  tts     - 语音合成"
    echo "  video   - 视频生成"
    echo "  image   - 图片生成"
    echo "  music   - 音乐生成"
}

# Main
main() {
    if [ $# -eq 0 ]; then
        show_help
        exit 0
    fi

    local command=$1
    shift

    case $command in
        chat)
            chat_command "$@"
            ;;
        tts|speech)
            tts_command "$@"
            ;;
        video)
            video_command "$@"
            ;;
        image|img)
            image_command "$@"
            ;;
        music)
            music_command "$@"
            ;;
        status)
            status_command
            ;;
        --help|-h|help)
            show_help
            ;;
        --version|-v)
            echo "minimax-cli v1.0.0"
            ;;
        *)
            echo -e "${RED}Unknown command: $command${NC}"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
